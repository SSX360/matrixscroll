{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "name": "matrixscroll-mcp",
  "displayName": "Matrix Scroll MCP",
  "version": "0.4.0",
  "description": "Thin-client MCP for local Ed25519 commit signing and offline envelope verification. Network features (Scroll Gate, audit export, chain verify) require an ssx360.com API key.",
  "maintainers": ["SSX360"],
  "homepage": "https://ssx360.com",
  "repository": "https://github.com/SSX360/matrixscroll",
  "documentation": "https://ssx360.com/docs#mcp",
  "transport": {
    "type": "stdio"
  },
  "packages": [
    {
      "registry": "pypi",
      "name": "matrixscroll",
      "version": "0.4.0",
      "extras": ["mcp"],
      "command": "matrixscroll-mcp"
    }
  ]
}
