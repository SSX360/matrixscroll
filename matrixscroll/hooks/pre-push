#!/bin/sh
# matrixscroll-git hook
set -e
python -m matrixscroll.git hook pre-push "$@" || {
  CONFIG="$PWD/.git/matrixscroll/config.json"
  ENFORCE=false
  if [ -f "$CONFIG" ]; then
    ENFORCE=$(python -c "import json; print(json.load(open(r'''$CONFIG''')).get('enforce', False))")
  fi
  if [ "$ENFORCE" = "True" ] || [ "$ENFORCE" = "true" ]; then
    echo "matrixscroll: envelope verification failed (enforce mode)" >&2
    exit 2
  fi
  echo "matrixscroll: envelope verification failed (warn mode)" >&2
}
exit 0
